  m_Script: {fileID: 11500000, guid: eb3fc8aa45803d6428a4e8a3a00a47e7, type: 3}
  m_Name: ConflictDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startLeft: {fileID: 594318413343068850, guid: 49f649cb454dcc94f832bed5d72d6d7d, type: 3}
  startRight: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
  lines:
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0413\u0415\u0419! \u0422\u043E\u0431\u0456 \u0441\u044E\u0434\u0438
      \u043D\u0435 \u043C\u043E\u0436\u043D\u0430!"
    textColor: {r: 0.7283019, g: 0.36951208, b: 0.19100742, a: 0}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 49f649cb454dcc94f832bed5d72d6d7d, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0412\u043E\u0443 \u0432\u043E\u0443 \u0442\u0438\u0445\u043E! \u042F
      \u0442\u0443\u0442 \u0432\u043F\u0435\u0440\u0448\u0435!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -8837407353033143914, guid: e12d55703a887d648bde4375eb4600d5, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0411\u043B\u044F\u0442\u044C \u0433\u043E\u0432\u043E\u0440\u044F\u0447\u0430
      \u0431\u0456\u043B\u043A\u0430? \u0429\u043E \u0437\u0430 \u043D\u0430\u0445?!)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: 277716514880280377, guid: a02c569c0a0634d42b049a042dcc800e, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0420\u043E\u0437\u0432\u0435\u0440\u0442\u0430\u0439\u0441\u044F! \u0422\u043E\u0431\u0456
      \u043D\u0435 \u0432 \u0446\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443!"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 0}
    isLeftCharacter: 0
    leftSprite: {fileID: 277716514880280377, guid: a02c569c0a0634d42b049a042dcc800e, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0417\u0430\u0441\u043F\u043E\u043A\u0456\u0439\u0441\u044F!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -7973728843418152914, guid: 310c818d9f5d23d4485f9927f52209e1, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u041F\u043E\u0441\u043B\u0443\u0445\u0430\u0439, \u043C\u0435\u043D\u0456
      \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u043E \u0434\u043E\u0431\u0440\u0430\u0442\u0438\u0441\u044F
      \u0434\u043E \u043C\u0456\u0441\u0442\u0430, \u044F \u043D\u0435 \u0437\u043D\u0430\u044E
      \u044F\u043A \u044F \u0442\u0443\u0442 \u043E\u043F\u0438\u043D\u0438\u0432\u0441\u044F
      \u0456 \u043D\u0435 \u0445\u043E\u0447\u0443 \u0441\u0442\u0432\u043E\u0440\u044E\u0432\u0430\u0442\u0438
      \u043F\u0440\u043E\u0431\u043B\u0435\u043C."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 745930c897c26e7449fa23188660c2a5, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0414\u043E\u043F\u043E\u043C\u043E\u0436\u0438 \u043C\u0435\u043D\u0456
      \u0432\u0438\u0431\u0440\u0430\u0442\u0438\u0441\u044F \u0437\u0432\u0456\u0434\u0441\u0438!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 745930c897c26e7449fa23188660c2a5, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0425\u043E\u0447\u0435\u0448 \u0432\u0438\u0431\u0440\u0430\u0442\u0438\u0441\u044F?
      \u0422\u043E \u0442\u043E\u0434\u0456 \u0440\u043E\u0437\u0432\u0435\u0440\u043D\u0438\u0441\u044F
      \u043D\u0430 180 \u0456 \u0432\u043F\u0435\u0440\u0435\u0434!"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 0}
    isLeftCharacter: 0
    leftSprite: {fileID: -8846523177901254147, guid: 745930c897c26e7449fa23188660c2a5, type: 3}
    rightSprite: {fileID: -647448164051440471, guid: f0da16af2991ebd4799e8c0dba007dab, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0422\u0456\u043B\u044C\u043A\u0438 \u0437\u043D\u0430\u0439, \u0432\u0438\u0445\u043E\u0434\u0443
      \u0437\u0432\u0456\u0434\u0441\u0438 \u043D\u0435\u043C\u0430!"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215688, a: 0}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 49f649cb454dcc94f832bed5d72d6d7d, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
