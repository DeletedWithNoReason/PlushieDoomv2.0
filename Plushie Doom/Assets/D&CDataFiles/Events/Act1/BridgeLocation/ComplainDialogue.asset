  lines:
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0422\u0410\u041A \u0406 \u0411\u0423\u0414\u0415\u0428 \u0417\u0410
      \u041C\u041D\u041E\u042E \u0425\u041E\u0414\u0418\u0422\u0418?!!!!"
    textColor: {r: 0.5849056, g: 0.21961544, b: 0.21961544, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -7973728843418152914, guid: 310c818d9f5d23d4485f9927f52209e1, type: 3}
    rightSprite: {fileID: 7801881510924318990, guid: a14c2dcc81df58e40902da849e0cb563, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041A\u043B\u043E\u043D"
    text: "\u041D\u0456\u0447\u043E\u0433\u043E \u043D\u0435 \u0432\u0434\u0456\u0454\u0448,
      \u043C\u0435\u043D\u0456 \u043D\u0443\u0434\u043D\u043E \u0456 \u044F \u0445\u043E\u0447\u0443
      \u0437\u0430 \u0442\u043E\u0431\u043E\u044E \u043F\u0456\u0442\u0438!"
    textColor: {r: 0.5849056, g: 0.21961544, b: 0.21961544, a: 0}
    isLeftCharacter: 0
    leftSprite: {fileID: -7973728843418152914, guid: 310c818d9f5d23d4485f9927f52209e1, type: 3}
    rightSprite: {fileID: 7985626363670038235, guid: 6c13410d94bbc81459a98b000437b5ca, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0411\u043B__\u044C \u043E\u0441\u0442\u0430\u043D\u043D\u0456\u0439
      \u0440\u0430\u0437 \u043F\u043E\u043F\u0435\u0440\u0435\u0434\u0436\u0430\u044E!"
    textColor: {r: 0.5849056, g: 0.21961544, b: 0.21961544, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: -7973728843418152914, guid: 310c818d9f5d23d4485f9927f52209e1, type: 3}
    rightSprite: {fileID: 7985626363670038235, guid: 6c13410d94bbc81459a98b000437b5ca, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041A\u043B\u043E\u043D"
    text: "\u0422\u0438 \u043D\u0456\u0447\u043E\u0433\u043E \u043D\u0435 \u0437\u0440\u043E\u0431\u0438\u0448!"
    textColor: {r: 0.5849056, g: 0.21961544, b: 0.21961544, a: 0}
