  m_Script: {fileID: 11500000, guid: eb3fc8aa45803d6428a4e8a3a00a47e7, type: 3}
  m_Name: SecondConflict_Data
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startLeft: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
  startRight: {fileID: 0}
  lines:
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0422\u0438 \u0437\u043D\u043E\u0432\u0443?! \u042F \u0436, \u0437\u0434\u0430\u0454\u0442\u044C\u0441\u044F,
      \u0447\u0456\u0442\u043A\u043E \u0441\u043A\u0430\u0437\u0430\u043B\u0430 \u2014
      \u0440\u043E\u0437\u0432\u0435\u0440\u0442\u0430\u0439\u0441\u044F \u0456 \u0439\u0434\u0438
      \u0433\u0435\u0442\u044C!"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 0126b4766dadd7349a8d124fd6923381, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u041F\u043E\u0441\u043B\u0443\u0445\u0430\u0439, \u044F \u043F\u0440\u043E\u0441\u0442\u043E
      \u043D\u0430\u043C\u0430\u0433\u0430\u044E\u0441\u044F \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0442\u0438,
      \u0434\u0435 \u044F. \u0422\u0438 \u0454\u0434\u0438\u043D\u0430, \u0445\u0442\u043E
      \u0442\u0443\u0442 \u0432\u0437\u0430\u0433\u0430\u043B\u0456 \u0440\u043E\u0437\u043C\u043E\u0432\u043B\u044F\u0454!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8837407353033143914, guid: aa39a7049b9627148a5b082bca7280d4, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 07607bc1d1841e64fbef59c50308c331, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0417\u0440\u043E\u0431\u0438\u0448 \u0449\u0435 \u0445\u043E\u0447 \u043A\u0440\u043E\u043A
      \u0443 \u0446\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u2014 \u0456
      \u043F\u043E\u0448\u043A\u043E\u0434\u0443\u0454\u0448, \u0449\u043E \u0432\u0437\u0430\u0433\u0430\u043B\u0456
      \u0441\u044C\u043E\u0433\u043E\u0434\u043D\u0456 \u043F\u0440\u043E\u043A\u0438\u043D\u0443\u0432\u0441\u044F."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: -8837407353033143914, guid: aa39a7049b9627148a5b082bca7280d4, type: 3}
    rightSprite: {fileID: -647448164051440471, guid: 9115496f93c2b314396643139a4d2c63, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0412\u043E\u043D\u0430 \u0430\u0431\u043E \u0441\u043A\u0430\u0436\u0435\u043D\u0430,
      \u0430\u0431\u043E \u0437\u0430 \u0446\u0456\u0454\u044E \u0430\u0433\u0440\u0435\u0441\u0456\u0454\u044E
      \u0445\u043E\u0432\u0430\u0454\u0442\u044C\u0441\u044F \u0449\u043E\u0441\u044C
      \u0441\u043F\u0440\u0430\u0432\u0434\u0456 \u0436\u0430\u0445\u043B\u0438\u0432\u0435...)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: -647448164051440471, guid: 9115496f93c2b314396643139a4d2c63, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0426\u0435 \u043C\u0456\u0439 \u043B\u0456\u0441! \u0406 \u044F \u043D\u0435
      \u0437\u0431\u0438\u0440\u0430\u044E\u0441\u044F \u0434\u0438\u0432\u0438\u0442\u0438\u0441\u044F,
      \u044F\u043A \u0447\u0435\u0440\u0433\u043E\u0432\u0438\u0439 \u0434\u0443\u0440\u0435\u043D\u044C
      \u0441\u0442\u0430\u0454 \u0434\u043E\u0431\u0440\u0438\u0432\u043E\u043C \u0434\u043B\u044F
      \u0446\u0438\u0445 \u0434\u0435\u0440\u0435\u0432 \u0447\u0435\u0440\u0435\u0437
      \u0441\u0432\u043E\u044E \u0442\u0443\u043F\u0456\u0441\u0442\u044C."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: 4311891725800045156, guid: 0126b4766dadd7349a8d124fd6923381, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u041E\u0441\u0442\u0430\u043D\u043D\u0454 \u043F\u043E\u043F\u0435\u0440\u0435\u0434\u0436\u0435\u043D\u043D\u044F:
      \u0437\u043D\u0438\u043A\u043D\u0438 \u0437 \u043C\u043E\u0457\u0445 \u043E\u0447\u0435\u0439,
      \u043F\u043E\u043A\u0438 \u043B\u0456\u0441 \u043D\u0435 \u0432\u0438\u0440\u0456\u0448\u0438\u0432,
      \u0449\u043E \u0442\u0438 \u2014 \u043B\u0435\u0433\u043A\u0430 \u0437\u0434\u043E\u0431\u0438\u0447."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0414\u043E\u0431\u0440\u0435, \u0434\u043E\u0431\u0440\u0435! \u042F
      \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0432. \u0412\u0436\u0435 \u0439\u0434\u0443..."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: e5d811344da219f4ea7e833fa3c99a7b, type: 3}
    customSpeed: 0.06
    muteSound: 0
