  m_Script: {fileID: 11500000, guid: eb3fc8aa45803d6428a4e8a3a00a47e7, type: 3}
  m_Name: OkIGoBack_Data
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startLeft: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
  startRight: {fileID: 0}
  lines:
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0421\u0445\u043E\u0436\u0435, \u0441\u043F\u0435\u0440\u0435\u0447\u0430\u0442\u0438\u0441\u044F
      \u0437 \u043D\u0435\u044E \u0437\u0430\u0440\u0430\u0437 \u2014 \u0446\u0435
      \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0430\u044F\u0442\u0438 \u0447\u0430\u0441.)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: 0}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0413\u0430\u0440\u0430\u0437\u0434, \u044F \u043F\u0456\u0434\u0443.
      \u041D\u0435 \u0445\u043E\u0447\u0443 \u0441\u0442\u0432\u043E\u0440\u044E\u0432\u0430\u0442\u0438
      \u0437\u0430\u0439\u0432\u0438\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C
      \u043D\u0456 \u0442\u043E\u0431\u0456, \u043D\u0456 \u0441\u043E\u0431\u0456."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: 0}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u041C\u0443\u0434\u0440\u0435 \u0440\u0456\u0448\u0435\u043D\u043D\u044F.
      \u041F\u0440\u043E\u0441\u0442\u043E \u0442\u0440\u0438\u043C\u0430\u0439\u0441\u044F
      \u0441\u0442\u0435\u0436\u043A\u0438, \u0432\u043E\u043D\u0430 \u0432\u0438\u0432\u0435\u0434\u0435
      \u0442\u0435\u0431\u0435."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 0}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u041E, \u044F \u043F\u0456\u0448\u043E\u0432."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0410\u043B\u0435 \u0441\u0435\u0440\u0439\u043E\u0437\u043D\u043E...
      \u0429\u043E \u0437 \u043D\u0435\u044E \u043D\u0435 \u0442\u0430\u043A? \u0412\u043E\u043D\u0430
      \u043F\u043E\u0432\u043E\u0434\u0438\u0442\u044C\u0441\u044F \u0442\u0430\u043A,
      \u043D\u0430\u0447\u0435 \u0437\u043D\u0430\u0454 \u043F\u0440\u043E \u043C\u0435\u043D\u0435
      \u0431\u0456\u043B\u044C\u0448\u0435, \u043D\u0456\u0436 \u043A\u0430\u0436\u0435.)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0426\u044F \u0432\u0441\u044F \u0441\u0438\u0442\u0443\u0430\u0446\u0456\u044F
      \u043C\u0435\u043D\u0456 \u0434\u0443\u0436\u0435 \u043D\u0435 \u043F\u043E\u0434\u043E\u0431\u0430\u0454\u0442\u044C\u0441\u044F.)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2568205003190893465, guid: e86f72103835afa4683d98c6f2c5c632, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
