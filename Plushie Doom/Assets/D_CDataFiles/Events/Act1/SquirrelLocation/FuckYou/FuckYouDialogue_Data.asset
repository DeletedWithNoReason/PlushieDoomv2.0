  lines:
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0427\u041E\u041C\u0423 \u042F \u041C\u0410\u042E \u041F\u041E\u0412\u0415\u0420\u0422\u0410\u0422\u0418\u0421\u042F
      \u041D\u0410\u0417\u0410\u0414?!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -7973728843418152914, guid: 85403cc79e0f91748b65d49064f96126, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.03
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u2026"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 1
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u2026\u0435\u0435\u0435 \u0432\u0438\u0431\u0430\u0447, \u0449\u043E
      \u043D\u0430\u043A\u0440\u0438\u0447\u0430\u0432. \u0410\u043B\u0435 \u0442\u0438
      \u043D\u0435 \u0445\u043E\u0442\u0456\u043B\u0430 \u043C\u0435\u043D\u0435
      \u043F\u043E\u0441\u043B\u0443\u0445\u0430\u0442\u0438!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u2026"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 1
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0427\u043E\u043C\u0443 \u0442\u0435\u0431\u0435 \u0442\u0430\u043A \u0442\u044F\u0433\u043D\u0435
      \u0441\u044E\u0434\u0438?"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 5634307206375098475, guid: 63d7a1669dd9da6488a9edd3cdaac316, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u041D\u0443\u2026 \u043F\u043E-\u043F\u0435\u0440\u0448\u0435, \u044F
      \u043C\u043E\u0436\u0443 \u043D\u0435 \u0437\u0443\u0441\u0442\u0440\u0456\u0442\u0438
      \u0449\u0435 \u043A\u043E\u0433\u043E\u0441\u044C. \u0410 \u043F\u043E-\u0434\u0440\u0443\u0433\u0435,
      \u044F \u043D\u0456\u043A\u0443\u0434\u0438 \u043D\u0435 \u043F\u0456\u0434\u0443,
      \u043F\u043E\u043A\u0438 \u0445\u0442\u043E\u0441\u044C \u043C\u0435\u043D\u0456
      \u043D\u0435 \u043F\u043E\u044F\u0441\u043D\u0438\u0442\u044C, \u0434\u0435
      \u044F \u0431\u043B\u0456\u043D \u0437\u043D\u0430\u0445\u043E\u0434\u0436\u0443\u0441\u044C!"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0422\u0430\u043A \u044F\u043A \u0442\u0443\u0442 \u0432\u0441\u0435
      \u0432\u0438\u0433\u043B\u044F\u0434\u0430\u0454 \u043D\u0435 \u0436\u0438\u0432\u0438\u043C,
      \u0442\u043E \u0446\u0435 \u043C\u0435\u043D\u0435 \u043D\u0430\u0441\u0442\u043E\u0440\u043E\u0436\u0443\u0454.
      \u0406 \u0442\u0438 \u0441\u0445\u043E\u0436\u0435 \u043D\u0435 \u043E\u0441\u043E\u0431\u043B\u0438\u0432\u043E
      \u043F\u0435\u0440\u0435\u0439\u043C\u0430\u0454\u0448\u0441\u044F \u0442\u0438\u043C,
      \u0449\u043E \u0442\u0438 \u043C\u0430\u0431\u0443\u0442\u044C \u0432\u043F\u0435\u0440\u0448\u0435
      \u0431\u0430\u0447\u0438\u0448 \u043C\u0435\u043D\u0435."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u2026"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 1
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0421\u0445\u043E\u0436\u0435, \u0442\u0438 \u0449\u0435 \u043D\u0435
      \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0432, \u0449\u043E \u0432\u0456\u0434\u0431\u0443\u0432\u0430\u0454\u0442\u044C\u0441\u044F\u2026
      \u0422\u0438 \u043D\u0435 \u0437 \u0442\u0438\u0445, \u043A\u0438\u043C \u043B\u0435\u0433\u043A\u043E
      \u043C\u0430\u043D\u0456\u043F\u0443\u043B\u044E\u0432\u0430\u0442\u0438. \u041C\u043E\u0436\u043B\u0438\u0432\u043E,
      \u0434\u043B\u044F \u0442\u0435\u0431\u0435 \u0446\u0435 \u0448\u0430\u043D\u0441..."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0413\u0430\u0440\u0430\u0437\u0434, \u0445\u043E\u0434\u0456\u043C\u043E
      \u0434\u043E \u043C\u043E\u0433\u043E \u0431\u0443\u0434\u0438\u043D\u043A\u0443,
      \u044F \u0442\u043E\u0431\u0456 \u0432\u0441\u0435 \u0440\u043E\u0437\u043A\u0430\u0436\u0443,
      \u0432\u0456\u043D \u044F\u043A \u0440\u0430\u0437 \u043F\u043E \u0434\u043E\u0440\u043E\u0437\u0456
      \u043B\u0456\u0432\u043E\u0440\u0443\u0447, \u043A\u0443\u0434\u0438 \u0442\u0438
      \u043F\u0440\u044F\u043C\u0443\u0432\u0430\u0432."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
