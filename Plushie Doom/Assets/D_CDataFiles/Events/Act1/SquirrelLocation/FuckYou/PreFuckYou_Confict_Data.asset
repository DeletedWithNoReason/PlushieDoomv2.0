    leftSprite: {fileID: -7251157837314978728, guid: 3d793678be23de14bbf88151ab43a52c, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.07
    muteSound: 1
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0426\u0435 \u0441\u0442\u0432\u043E\u0440\u0456\u043D\u043D\u044F \u0434\u0443\u043C\u0430\u0454,
      \u0449\u043E \u043C\u043E\u0436\u0435 \u0432\u043A\u0430\u0437\u0443\u0432\u0430\u0442\u0438
      \u043C\u0435\u043D\u0456)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 8998112352109675948, guid: eb6778a56bd511f4da68f0aad1dd1439, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.07
    muteSound: 1
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u041D\u0435 \u0442\u0435 \u0449\u043E\u0431 \u044F \u0431\u0443\u0432
      \u0432\u043F\u0435\u0432\u043D\u0435\u043D\u0438\u0439, \u043D\u0430 \u0449\u043E
      \u0432\u043E\u043D\u0430 \u0437\u0434\u0430\u0442\u043D\u0430...)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 8998112352109675948, guid: eb6778a56bd511f4da68f0aad1dd1439, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.07
    muteSound: 1
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "(\u0410\u043B\u0435 \u044F \u043D\u0435 \u0437\u0431\u0438\u0440\u0430\u044E\u0441\u044C
      \u0432\u0456\u0434\u0441\u0442\u0443\u043F\u0430\u0442\u0438...)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352943, a: 1}
