  lines:
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0410\u0433\u0430, \u0437\u043D\u0430\u0447\u0438\u0442\u044C \u043E\u043D
      \u0432\u043E\u043D\u043E \u044F\u043A...)"
