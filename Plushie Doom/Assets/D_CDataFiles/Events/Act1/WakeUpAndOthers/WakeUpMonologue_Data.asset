  m_Script: {fileID: 11500000, guid: eb3fc8aa45803d6428a4e8a3a00a47e7, type: 3}
  m_Name: WakeUpMonologue_Data
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startLeft: {fileID: -4836102581344303206, guid: 561132940120a0a4da3f8ef1c55cf9bc, type: 3}
  startRight: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
  lines:
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0410\u0430\u0430\u2026 \u0433\u043E\u043B\u043E\u0432\u0430 \u0440\u043E\u0437\u043A\u043E\u043B\u044E\u0454\u0442\u044C\u0441\u044F\u2026
      \u0434\u0435 \u044F?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -4836102581344303206, guid: 561132940120a0a4da3f8ef1c55cf9bc, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0411\u043B\u0456\u043D, \u044F\u043A \u044F \u0442\u0443\u0442 \u043E\u043F\u0438\u043D\u0438\u0432\u0441\u044F?
      \u042F \u0441\u043F\u043B\u044E? \u042F \u0440\u0435\u0430\u043B\u044C\u043D\u043E
      \u0442\u0443\u0442?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u042F\u2026)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.06
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0411\u043B\u044F\u0434\u044C! \u042F \u043D\u0430\u0432\u0456\u0442\u044C
      \u043D\u0435 \u043F\u0430\u043C\u2019\u044F\u0442\u0430\u044E, \u044F\u043A
      \u043C\u0435\u043D\u0435 \u0437\u0432\u0430\u0442\u0438!)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 0}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.03
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0410\u0439... \u043F\u043E\u0445\u0443\u0439. \u041D\u0430\u0437\u0432\u0443
      \u0441\u0435\u0431\u0435 \u041C\u0435\u0442\u044C\u044E. \u041E\u043A\u0435\u0439
      \u041C\u0435\u0442 \u0434\u0443\u043C\u0430\u0439, \u0434\u0443\u043C\u0430\u0439.
      \u0429\u043E \u044F \u043F\u0430\u043C'\u044F\u0442\u0430\u044E?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -4836102581344303206, guid: 561132940120a0a4da3f8ef1c55cf9bc, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0414\u0440\u0443\u0433\u2026 \u044F \u0436 \u0448\u0443\u043A\u0430\u0432
      \u0439\u043E\u0433\u043E. \u0429\u043E \u043C\u0438 \u0432\u0437\u0430\u0433\u0430\u043B\u0456
      \u0440\u043E\u0431\u0438\u043B\u0438?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0429\u043E \u0437\u0430?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8837407353033143914, guid: aa39a7049b9627148a5b082bca7280d4, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.03
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0414\u0415 \u041C\u041E\u042F \u041C\u041E\u0411\u0406\u041B\u0410?!)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -7973728843418152914, guid: 85403cc79e0f91748b65d49064f96126, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.03
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0421\u043F\u043E\u043A\u0456\u0439\u043D\u043E. \u041C\u043E\u0436\u0435,
      \u043C\u0435\u043D\u0435 \u0432\u0438\u0440\u0443\u0431\u0438\u043B\u0438 \u0456
      \u043E\u0431\u0456\u043A\u0440\u0430\u043B\u0438. \u0422\u0440\u0435\u0431\u0430
      \u0437\u043D\u0430\u0439\u0442\u0438 \u0434\u043E\u0440\u043E\u0433\u0443 \u0434\u043E
      \u043C\u0456\u0441\u0442\u0430. \u0411\u0443\u0434\u044C-\u043A\u0443\u0434\u0438,
      \u0434\u0435 \u0454 \u043B\u044E\u0434\u0438.)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -4836102581344303206, guid: 2b42b39b5b49af24bbf84abd2722179e, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0422\u0456\u043B\u044C\u043A\u0438 \u0449\u043E\u0441\u044C \u043C\u0435\u043D\u0456
      \u043D\u0435 \u043F\u043E\u0434\u043E\u0431\u0430\u0454\u0442\u044C\u0441\u044F
      \u0446\u0435 \u043C\u0456\u0441\u0446\u0435... \u0422\u0443\u0442 \u043D\u0456
      \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0457 \u0442\u0440\u0430\u0432\u0438,
      \u043D\u0456 \u0434\u0435\u0440\u0435\u0432, \u0432\u0437\u0430\u0433\u0430\u043B\u0456
      \u043D\u0456\u0447\u043E\u0433\u043E, \u0432\u0441\u0435 \u0437 \u0434\u043E\u0432\u0431\u0430\u043D\u043E\u0433\u043E
      \u0444\u0435\u0442\u0440\u0443!)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0421\u043F\u043E\u0434\u0456\u0432\u0430\u044E\u0441\u044C, \u0446\u0435
      \u043F\u0440\u043E\u0441\u0442\u043E \u044F\u043A\u0456\u0441\u044C \u0434\u0435\u043A\u043E\u0440\u0430\u0446\u0456\u0457\u2026)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: bdb6994165688774b99fc8e628fc9b2b, type: 3}
    customSpeed: 0.06
    muteSound: 0
