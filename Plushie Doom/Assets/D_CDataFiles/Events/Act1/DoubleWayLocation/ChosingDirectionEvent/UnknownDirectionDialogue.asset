  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0406 \u043A\u0443\u0434\u0438 \u043C\u0435\u043D\u0456 \u043F\u0456\u0442\u0438?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: 3622792381989719942, guid: 26209861f8fb39441bf790c33a08e0d4, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: faac6265a62afd14dbdc457e99abbac9, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: 
    text: "\u041D\u0430 \u043B\u0456\u0432\u0456\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0456
      \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E: \"\u041D\u0415 \u0419\u0414\u0406\u0422\u042C
      \u0422\u0423\u0414\u0418\", \u043F\u0456\u0434 \u043D\u0438\u043C \u043B\u0435\u0434\u044C
      \u043F\u043E\u043C\u0456\u0442\u043D\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E
      \u043E\u0440\u0438\u0433\u0456\u043D\u0430\u043B\u044C\u043D\u0438\u0439 \u0442\u0435\u043A\u0441\u0442
      \"\u0414\u0456\u043C \u0431\u0456\u043B\u043A\u0438\""
    textColor: {r: 0.1882353, g: 0.1882353, b: 0.1882353, a: 0}
    isLeftCharacter: 1
    leftSprite: {fileID: 8995154407686431259, guid: faac6265a62afd14dbdc457e99abbac9, type: 3}
    rightSprite: {fileID: 8995154407686431259, guid: faac6265a62afd14dbdc457e99abbac9, type: 3}
    customSpeed: 0.05
    muteSound: 1
  - characterName: 
    text: "\u041D\u0430 \u043F\u0440\u0430\u0432\u0456\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0456
      \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E: \"\u0412\u043E\u0432\u0447\u0435
      \u043B\u0456\u0433\u0432\u043E\" \u0456 \"\u041A\u0430\u0440\u0442\u043E\u043D\u043D\u0435
      \u043C\u0456\u0441\u0442\u0435\u0447\u043A\u043E\""
    textColor: {r: 0.1882353, g: 0.1882353, b: 0.1882353, a: 0}
