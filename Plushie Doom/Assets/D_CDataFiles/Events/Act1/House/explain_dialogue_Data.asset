  m_Script: {fileID: 11500000, guid: eb3fc8aa45803d6428a4e8a3a00a47e7, type: 3}
  m_Name: explain_dialogue_Data
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startLeft: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
  startRight: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
  lines:
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0414\u0456\u043C, \u043C\u0438\u043B\u0438\u0439 \u0434\u0456\u043C..."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u041D\u0443 \u0449\u043E \u0436... \u043B\u0430\u0441\u043A\u0430\u0432\u043E
      \u043F\u0440\u043E\u0441\u0438\u043C\u043E \u0434\u043E \u043C\u043E\u0433\u043E
      \u0437\u0430\u043C\u043A\u0443. \u041F\u0440\u043E\u0445\u043E\u0434\u044C,
      \u043D\u0435 \u0441\u0442\u0456\u0439 \u043D\u0430 \u043F\u043E\u0440\u043E\u0437\u0456,
      \u0445\u043E\u0447\u0430 \u0442\u0443\u0442 \u0456 \u043F\u043E\u0440\u043E\u0433\u0430
      \u044F\u043A \u0442\u0430\u043A\u043E\u0433\u043E \u043D\u0435\u043C\u0430\u0454."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0414\u043E \u0440\u0435\u0447\u0456 \u044F \u0431\u0456\u043B\u043A\u0430,
      \u043C\u043E\u0436\u0435\u0448 \u0442\u0430\u043A \u043C\u0435\u043D\u0435
      \u043D\u0430\u0437\u0438\u0432\u0430\u0442\u0438."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u041D\u0443 \u0430 \u044F \u041C\u0435\u0442\u044C\u044E, \u0430\u043B\u0435
      \u043C\u043E\u0436\u0435\u0448 \u043D\u0430\u0437\u0438\u0432\u0430\u0442\u0438
      \u043C\u0435\u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u041C\u0435\u0442."
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u0422\u0443\u0442... \u043D\u0435\u0439\u043C\u043E\u0432\u0456\u0440\u043D\u043E
      \u0442\u0456\u0441\u043D\u043E. \u0421\u0442\u0456\u043D\u0438 \u043C'\u044F\u043A\u0456,
      \u043D\u0430\u0447\u0435 \u044F \u0432\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0456
      \u044F\u043A\u043E\u0457\u0441\u044C \u043F\u043E\u0434\u0443\u0448\u043A\u0438.
      \u0406 \u0446\u0435\u0439 \u0437\u0430\u043F\u0430\u0445... \u0441\u0442\u0430\u0440\u043E\u0457
      \u0432\u043E\u0432\u043D\u0438 \u0442\u0430 \u043F\u0438\u043B\u0443.)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0423 \u0442\u0435\u0431\u0435 \u0442\u0443\u0442... \u0441\u043F\u0435\u0446\u0438\u0444\u0456\u0447\u043D\u043E.
      \u0427\u043E\u043C\u0443 \u0432 \u0442\u043E\u043C\u0443 \u044F\u0449\u0438\u043A\u0443
      \u0442\u0430\u043A \u0431\u0430\u0433\u0430\u0442\u043E \u0433\u0443\u0434\u0437\u0438\u043A\u0456\u0432?
      \u0422\u0438 \u0457\u0445 \u043A\u043E\u043B\u0435\u043A\u0446\u0456\u043E\u043D\u0443\u0454\u0448?"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0413\u0443\u0434\u0437\u0438\u043A\u0438 \u2014 \u0446\u0435 \u0442\u0435,
      \u0449\u043E \u0442\u0440\u0438\u043C\u0430\u0454 \u043D\u0430\u0441 \u043A\u0443\u043F\u0456,
      \u041C\u0435\u0442\u044C\u044E. \u0411\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E.
      \u042F\u043A\u0449\u043E \u0442\u0438 \u043F\u043E\u0447\u043D\u0435\u0448
      \u0440\u043E\u0437\u0441\u0438\u043F\u0430\u0442\u0438\u0441\u044F, \u0442\u0438
      \u0442\u0435\u0436 \u0448\u0443\u043A\u0430\u0442\u0438\u043C\u0435\u0448,
      \u0447\u0438\u043C \u043F\u0440\u0438\u0448\u0438\u0442\u0438 \u0441\u0435\u0431\u0435
      \u043D\u0430\u0437\u0430\u0434 \u0434\u043E \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0456."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 7037289892578927308, guid: 9060b6ef25792a343b8a58620b4e86e9, type: 3}
    customSpeed: 0.06
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0429\u043E \u0442\u0438 \u043C\u0430\u0454\u0448 \u043D\u0430 \u0443\u0432\u0430\u0437\u0456
      \u043F\u0456\u0434 \xAB\u0440\u043E\u0437\u0441\u0438\u043F\u0430\u0442\u0438\u0441\u044F\xBB?
      \u041F\u043E\u0441\u043B\u0443\u0445\u0430\u0439, \u0442\u0438 \u043E\u0431\u0456\u0446\u044F\u043B\u0430
      \u0440\u043E\u0437\u043F\u043E\u0432\u0456\u0441\u0442\u0438, \u0434\u0435
      \u044F. \u0426\u0435 \u043C\u0456\u0441\u0446\u0435... \u0446\u0435 \u0436
      \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u0456\u0441, \u0442\u0430\u043A?"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 2186889173539803145, guid: 3f2caaaa808390345b22120381d5e251, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0426\u0435 \u044F\u043C\u0430, \u041C\u0435\u0442\u044C\u044E. \u0414\u0443\u0436\u0435
      \u0433\u043B\u0438\u0431\u043E\u043A\u0430, \u043C'\u044F\u043A\u0430 \u0456
      \u043D\u0435\u0439\u043C\u043E\u0432\u0456\u0440\u043D\u043E \u0437\u0430\u0442\u0438\u0448\u043D\u0430
      \u044F\u043C\u0430. \u0422\u0438 \u0432 \u0413\u043E\u0440\u0456\u0445\u043E\u0432\u043E\u043C\u0443
      \u041B\u0456\u0441\u0456, \u0430\u043B\u0435 \u0446\u0435 \u043B\u0438\u0448\u0435
      \u043D\u0430\u0437\u0432\u0430 \u043D\u0430 \u0435\u0442\u0438\u043A\u0435\u0442\u0446\u0456."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 7037289892578927308, guid: 9060b6ef25792a343b8a58620b4e86e9, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0422\u0438 \u043F\u043E\u0442\u0440\u0430\u043F\u0438\u0432 \u0443 \u0441\u0432\u0456\u0442,
      \u0434\u0435 \u043F\u0440\u0430\u0432\u0434\u0430 \u2014 \u0446\u0435 \u0437\u0430\u043D\u0430\u0434\u0442\u043E
      \u0433\u043E\u0441\u0442\u0440\u0438\u0439 \u043F\u0440\u0435\u0434\u043C\u0435\u0442,
      \u0449\u043E\u0431 \u0439\u043E\u0433\u043E \u0442\u0440\u0438\u043C\u0430\u0442\u0438
      \u0432 \u0440\u0443\u043A\u0430\u0445. \u0422\u043E\u043C\u0443 \u0442\u0443\u0442
      \u0432\u0441\u0435 \u0444\u0435\u0442\u0440\u043E\u0432\u0435. \u0429\u043E\u0431
      \u043D\u0456\u0445\u0442\u043E \u043D\u0435 \u043F\u043E\u0440\u0430\u043D\u0438\u0432\u0441\u044F
      \u043E\u0431 \u043F\u0430\u043C'\u044F\u0442\u044C."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u042F \u043F\u0430\u043C'\u044F\u0442\u0430\u044E \u043F\u043E\u0442\u044F\u0433...
      \u0421\u043A\u0440\u0435\u0433\u0456\u0442 \u043C\u0435\u0442\u0430\u043B\u0443.
      \u0426\u0435 \u0431\u0443\u043B\u043E \u0442\u0430\u043A \u0440\u0435\u0430\u043B\u044C\u043D\u043E,
      \u0430 \u043F\u043E\u0442\u0456\u043C... \u0432\u0441\u0435 \u0441\u0442\u0430\u043B\u043E...
      \u044F\u0441\u043A\u0440\u0430\u0432\u0456\u0448\u0438\u043C?"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0413\u043E\u0441\u043F\u043E\u0434\u0430\u0440 \u0446\u044C\u043E\u0433\u043E
      \u043C\u0456\u0441\u0446\u044F... \u0412\u0435\u043B\u0438\u043A\u0438\u0439
      \u041F\u0435\u0441. \u0412\u0456\u043D \u0445\u043E\u0447\u0435, \u0449\u043E\u0431
      \u0442\u043E\u0431\u0456 \u0431\u0443\u043B\u043E \u0434\u043E\u0431\u0440\u0435.
      \u0410\u043B\u0435 \xAB\u0434\u043E\u0431\u0440\u0435\xBB \u0442\u0443\u0442
      \u043E\u0437\u043D\u0430\u0447\u0430\u0454 \xAB\u043D\u0456\u0447\u043E\u0433\u043E
      \u043D\u0435 \u043F\u0430\u043C'\u044F\u0442\u0430\u0442\u0438\xBB. \u0422\u0456
      \u0442\u0430\u0431\u043B\u0435\u0442\u043A\u0438, \u0449\u043E \u0442\u043E\u0431\u0456
      \u043F\u0440\u043E\u043F\u043E\u043D\u0443\u0432\u0430\u0442\u0438\u043C\u0443\u0442\u044C
      \u2014 \u0446\u0435 \u043A\u043B\u0435\u0439. \u0412\u043E\u043D\u0438 \u0437\u0430\u043A\u043B\u0435\u044E\u044E\u0442\u044C
      \u0434\u0456\u0440\u043A\u0438 \u0443 \u0433\u043E\u043B\u043E\u0432\u0456."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 7037289892578927308, guid: 9060b6ef25792a343b8a58620b4e86e9, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u042F\u043A\u0449\u043E \u0442\u0438 \u043F\u043E\u0447\u043D\u0435\u0448
      \u0457\u0445 \u0457\u0441\u0442\u0438, \u0442\u043E \u0432 \u0442\u043E\u0431\u0456
      \u0437\u0430\u043B\u0438\u0448\u0430\u0442\u0438\u043C\u0435\u0442\u044C\u0441\u044F
      \u0432\u0441\u0435 \u043C\u0435\u043D\u0448\u0435 \u041C\u0435\u0442\u044C\u044E,
      \u0456 \u0441\u0442\u0430\u0432\u0430\u0442\u0438\u043C\u0435 \u0432\u0441\u0435
      \u0431\u0456\u043B\u044C\u0448\u0435... \u0456\u0433\u0440\u0430\u0448\u043A\u0438.
      \u041F\u043E\u0433\u043B\u044F\u043D\u044C \u043D\u0430 \u0441\u0432\u043E\u0457
      \u0440\u0443\u043A\u0438. \u0422\u0438 \u0432\u0436\u0435 \u0432\u0456\u0434\u0447\u0443\u0432\u0430\u0454\u0448,
      \u044F\u043A \u0448\u043A\u0456\u0440\u0430 \u0441\u0442\u0430\u0454 \u0441\u0445\u043E\u0436\u043E\u044E
      \u043D\u0430 \u0442\u043A\u0430\u043D\u0438\u043D\u0443?"
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "(\u042F \u043C\u0438\u043C\u043E\u0432\u043E\u043B\u0456 \u0434\u0438\u0432\u043B\u044E\u0441\u044F
      \u043D\u0430 \u0441\u0432\u043E\u0457 \u0434\u043E\u043B\u043E\u043D\u0456.
      \u041C\u0435\u043D\u0456 \u0437\u0434\u0430\u0454\u0442\u044C\u0441\u044F,
      \u0447\u0438 \u043B\u0456\u043D\u0456\u0457 \u043D\u0430 \u0448\u043A\u0456\u0440\u0456
      \u0441\u043F\u0440\u0430\u0432\u0434\u0456 \u0432\u0438\u0433\u043B\u044F\u0434\u0430\u044E\u0442\u044C
      \u044F\u043A \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u043D\u044F
      \u043D\u0438\u0442\u043E\u043A?)"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 277716514880280377, guid: 4e49cb1d331a1054f8d34f658f030051, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0426\u0435 \u043C\u0430\u0440\u0435\u043D\u043D\u044F... \u042F \u043C\u0430\u044E
      \u0437\u043D\u0430\u0439\u0442\u0438 \u0420\u043E\u0434\u043D\u0456. \u0412\u0456\u043D
      \u0431\u0443\u0432 \u0437\u0456 \u043C\u043D\u043E\u044E. \u0412\u0456\u043D
      \u0442\u0435\u0436 \u0442\u0443\u0442, \u0443 \u0446\u0456\u0439 \xAB\u044F\u043C\u0456\xBB?"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0422\u0432\u0456\u0439 \u0434\u0440\u0443\u0433... \u042F\u043A\u0449\u043E
      \u0432\u0456\u043D \u043F\u0456\u0448\u043E\u0432 \u0434\u0430\u043B\u0456
      \u0437\u0430 \u041D\u0430\u0433\u043B\u044F\u0434\u0430\u0447\u0435\u043C \u0443
      \u041A\u0430\u0440\u0442\u043E\u043D\u043D\u0435 \u041C\u0456\u0441\u0442\u043E,
      \u0442\u043E \u0432\u0456\u043D \u0432\u0436\u0435 \u043C\u043E\u0436\u0435
      \u0456 \u043D\u0435 \u0431\u0443\u0442\u0438 \u0420\u043E\u0434\u043D\u0456.
      \u0422\u0430\u043C, \u0437\u0430 \u043C\u043E\u0441\u0442\u043E\u043C, \u0437\u0430\u043F\u0435\u0440\u0435\u0447\u0435\u043D\u043D\u044F
      \u0441\u0442\u0430\u0454 \u0437\u0430\u043A\u043E\u043D\u043E\u043C."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: -8846523177901254147, guid: 656af330d35a1654aa1ba70b19828614, type: 3}
    rightSprite: {fileID: -5202214930234550693, guid: 8321895c101c2c243a5fcc40d2c59623, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0422\u0438 \u043C\u0430\u0454\u0448 \u0437\u043D\u0430\u0442\u0438:
      \u0446\u0435\u0439 \u0441\u0432\u0456\u0442 \u0436\u0438\u0432\u0438\u0442\u044C\u0441\u044F
      \u0442\u0432\u043E\u0457\u043C \u043D\u0435\u0431\u0430\u0436\u0430\u043D\u043D\u044F\u043C
      \u0431\u0430\u0447\u0438\u0442\u0438 \u043F\u0440\u0430\u0432\u0434\u0443.
      \u0422\u043E\u0439 \u041F\u0435\u0441 \u2014 \u0432\u0456\u043D \u043D\u0435
      \u043C\u043E\u043D\u0441\u0442\u0440, \u0432\u0456\u043D \u043F\u0440\u043E\u0441\u0442\u043E
      \u0456\u0434\u0435\u0430\u043B\u044C\u043D\u0438\u0439 \u043E\u0445\u043E\u0440\u043E\u043D\u0435\u0446\u044C.
      \u0412\u0456\u043D \u0431\u0443\u0434\u0443\u0454 \u0441\u0442\u0456\u043D\u0438
      \u0437 \u043A\u0430\u0440\u0442\u043E\u043D\u0443 \u0442\u0430\u043C, \u0434\u0435
      \u043F\u0440\u0456\u0440\u0432\u0430."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 5634307206375098475, guid: e9531c5a69e47424aa038f21bc0b905f, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u041C\u0435\u0442\u044C\u044E"
    text: "\u0422\u043E\u0431\u0442\u043E, \u044F\u043A\u0449\u043E \u044F \u0432\u0456\u0434\u043C\u043E\u0432\u043B\u044E\u0441\u044F
      \u0432\u0456\u0434 \u0442\u0438\u0445 \u0442\u0430\u0431\u043B\u0435\u0442\u043E\u043A...
      \u044F \u0437\u043C\u043E\u0436\u0443 \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438,
      \u0449\u043E \u043D\u0430\u0441\u043F\u0440\u0430\u0432\u0434\u0456 \u0441\u0442\u0430\u043B\u043E\u0441\u044F
      \u043D\u0430 \u0442\u0456\u0439 \u0437\u0430\u043B\u0456\u0437\u043D\u0438\u0446\u0456?"
    textColor: {r: 0.61960787, g: 0.27058825, b: 0.22352941, a: 1}
    isLeftCharacter: 1
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u041C\u043E\u0436\u043B\u0438\u0432\u043E. \u0410\u043B\u0435 \u0431\u0443\u0434\u044C
      \u043E\u0431\u0435\u0440\u0435\u0436\u043D\u0438\u043C. \u041A\u043E\u043B\u0438
      \u0444\u0435\u0442\u0440\u043E\u0432\u0456 \u0445\u043C\u0430\u0440\u0438 \u0440\u043E\u0437\u0445\u043E\u0434\u044F\u0442\u044C\u0441\u044F,
      \u043D\u0435\u0431\u043E \u043F\u0456\u0434 \u043D\u0438\u043C\u0438 \u043C\u043E\u0436\u0435
      \u0432\u0438\u044F\u0432\u0438\u0442\u0438\u0441\u044F \u0437\u0430\u043D\u0430\u0434\u0442\u043E
      \u0445\u043E\u043B\u043E\u0434\u043D\u0438\u043C \u0434\u043B\u044F \u043F\u043B\u044E\u0448\u0435\u0432\u043E\u0433\u043E
      \u0432\u0435\u0434\u043C\u0435\u0434\u0438\u043A\u0430."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 594318413343068850, guid: 4dbfad9e602c0744e8743093f0fbdbda, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: e5d811344da219f4ea7e833fa3c99a7b, type: 3}
    customSpeed: 0.06
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0412\u0456\u0434\u043F\u043E\u0447\u0438\u043D\u044C \u0442\u0443\u0442
      \u0442\u0440\u043E\u0445\u0438. \u0422\u043E\u0439 \u0432\u0435\u043B\u0438\u043A\u0438\u0439
      \u0432\u043E\u043B\u043E\u0445\u0430\u043D\u044C \u043D\u0435 \u0437\u0430\u0439\u0434\u0435
      \u0432 \u043C\u043E\u0454 \u0434\u0443\u043F\u043B\u043E \u2014 \u0432\u0456\u043D
      \u0437\u0430\u043D\u0430\u0434\u0442\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0439
      \u0434\u043B\u044F \u0442\u0456\u0454\u0457 \u043F\u0440\u0430\u0432\u0434\u0438,
      \u0449\u043E \u0442\u0443\u0442 \u0437\u0430\u0445\u043E\u0432\u0430\u043D\u0430."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
  - characterName: "\u0411\u0456\u043B\u043A\u0430"
    text: "\u0410 \u043F\u043E\u0442\u0456\u043C \u0432\u0438\u0440\u0456\u0448\u0443\u0439:
      \u0441\u043E\u043B\u043E\u0434\u043A\u0435 \u0437\u0430\u0431\u0443\u0442\u0442\u044F
      \u0447\u0438 \u0431\u043E\u043B\u044E\u0447\u0438\u0439 \u0448\u043B\u044F\u0445
      \u0434\u043E\u0434\u043E\u043C\u0443."
    textColor: {r: 0.7294118, g: 0.36862746, b: 0.19215687, a: 1}
    isLeftCharacter: 0
    leftSprite: {fileID: 3622792381989719942, guid: b681071729a1a1d4194936d6fb11b726, type: 3}
    rightSprite: {fileID: 4976209641032181745, guid: 10ddfb43fa06588459313c0294d61132, type: 3}
    customSpeed: 0.05
    muteSound: 0
